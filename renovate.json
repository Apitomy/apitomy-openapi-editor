{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "enabledManagers": [
        "npm"
    ],
    "dependencyDashboard": true,
    "rangeStrategy": "bump",
    "ignorePaths": [
        "test-app/**"
    ],
    "prConcurrentLimit": 5,
    "prHourlyLimit": 5,
    "packageRules": [
        {
            "groupName": "Dependencies: Typescript",
            "matchFileNames": [
                "package.json"
            ],
            "enabled": true,
            "matchUpdateTypes": [
                "patch", "minor"
            ]
        },
        {
            "groupName": "Dependencies: Typescript (Major)",
            "matchFileNames": [
                "package.json"
            ],
            "enabled": true,
            "matchUpdateTypes": [
                "major"
            ],
            "schedule": [ "* 0 1 * *" ]
        }
    ]
}
