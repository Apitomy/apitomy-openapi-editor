{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "enabledManagers": [
        "npm"
    ],
    "dependencyDashboard": true,
    "rangeStrategy": "bump",
    "ignorePaths": [
        "test-app/**"
    ],
    "prConcurrentLimit": 5,
    "prHourlyLimit": 5,
    "ignoreDeps": [],
    "packageRules": [
        {
            "description": "Ignore peerDependencies",
            "matchDepTypes": ["peerDependencies"],
            "enabled": false
        },
        {
            "groupName": "Dependencies: Typescript",
            "matchFileNames": [
                "package.json"
            ],
            "enabled": true,
            "matchUpdateTypes": [
                "patch",
                "minor"
            ]
        },
        {
            "groupName": "Dependencies: Typescript (Major)",
            "matchFileNames": [
                "package.json"
            ],
            "enabled": true,
            "matchUpdateTypes": [
                "major"
            ],
            "schedule": [
                "* 0 1 * *"
            ]
        },
        {
            "description": "Label minor dependency updates",
            "matchUpdateTypes": [
                "minor"
            ],
            "labels": [
                "area/dependencies",
                "update/minor"
            ]
        },
        {
            "description": "Label patch dependency updates",
            "matchUpdateTypes": [
                "patch"
            ],
            "labels": [
                "area/dependencies",
                "update/patch"
            ]
        }
    ]
}
